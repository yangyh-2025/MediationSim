%%%%%%%%%%%%%%%%%%%%%%%%%%%
%  Fudan IR Color Theme
%  Based on Fudan blue (#002F6C) and warm gold accent (#C8963E)
%%%%%%%%%%%%%%%%%%%%%%%%%%%
\definecolor{fudanblue}{RGB}{0, 47, 108}
\definecolor{fudangold}{RGB}{200, 150, 62}
\definecolor{darknavy}{RGB}{20, 35, 65}
\definecolor{lightgray}{RGB}{242, 242, 242}
\definecolor{mediumgray}{RGB}{180, 180, 180}
\definecolor{accentred}{RGB}{180, 45, 45}
\definecolor{accentteal}{RGB}{0, 130, 145}
\definecolor{purewhite}{RGB}{255, 255, 255}
\definecolor{pureblack}{RGB}{0, 0, 0}
\definecolor{softgold}{RGB}{245, 235, 210}

% ====================
% Theme
% ====================

% Basic colors
\setbeamercolor{palette primary}{fg=pureblack,bg=purewhite}
\setbeamercolor{palette secondary}{fg=pureblack,bg=purewhite}
\setbeamercolor{palette tertiary}{bg=pureblack,fg=purewhite}
\setbeamercolor{palette quaternary}{fg=pureblack,bg=purewhite}
\setbeamercolor{structure}{fg=fudanblue}

% Headline
\setbeamercolor{headline}{fg=purewhite,bg=fudanblue}
\setbeamercolor{headline rule}{bg=fudanblue}

% Block
\setbeamercolor{block title}{fg=fudanblue,bg=purewhite}
\setbeamercolor{block separator}{bg=fudangold}
\setbeamercolor{block body}{fg=pureblack,bg=purewhite}

% Alert Block
\setbeamercolor{block alerted title}{fg=fudanblue,bg=softgold}
\setbeamercolor{block alerted separator}{bg=fudangold}
\setbeamercolor{block alerted body}{fg=pureblack,bg=softgold}

% Heading
\setbeamercolor{heading}{fg=fudanblue}

% Itemize
\setbeamercolor{item}{fg=fudangold}

% Bibliography
\setbeamercolor{bibliography item}{fg=pureblack}
\setbeamercolor{bibliography entry author}{fg=pureblack}
\setbeamercolor{bibliography entry title}{fg=pureblack}
\setbeamercolor{bibliography entry location}{fg=pureblack}
\setbeamercolor{bibliography entry note}{fg=pureblack}
\setbeamertemplate{bibliography entry article}{}
\setbeamertemplate{bibliography entry title}{}
\setbeamertemplate{bibliography entry location}{}
\setbeamertemplate{bibliography entry note}{}

% Footer
\setbeamercolor{footline}{fg=purewhite,bg=fudanblue}
