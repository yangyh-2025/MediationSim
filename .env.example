# ============================================
# 偏见调停多智能体模拟系统 — 配置文件
# 复制为 .env 并填入你的配置
# ============================================

# OpenAI 兼容 API 密钥（必填）
OPENAI_API_KEY=sk-your-key-here

# API 地址（默认 OpenAI 官方，可改为中转站）
# OPENAI_BASE_URL=https://api.openai.com/v1

# 模型名称（可选，默认 gpt-4o）
# LLM_MODEL=gpt-4o

# LLM 调用全局最大并发（可选，默认 5）
# 每次谈判轮次有 ~5 个 agent 同时调用，多个条件并行。
# 降低可以避免 API 限流，提高可能加速但易被限。
# LLM_CONCURRENCY=5
